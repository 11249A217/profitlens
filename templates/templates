<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ProfitLens — P&L Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=Figtree:wght@400;500;600&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#F8F7F4;--surface:#FFFFFF;--surface2:#F3F4F6;--border:#E5E7EB;
  --green:#1D9E75;--gdim:rgba(29,158,117,0.12);
  --red:#D85A30;--rdim:rgba(216,90,48,0.12);
  --blue:#378ADD;--yellow:#BA7517;
  --text:#111827;--muted:#6B7280;--sidebar:#111827;
  --font:'Figtree',sans-serif;--mono:'DM Mono',monospace;--head:'Syne',sans-serif;--r:12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;}

/* ── AUTH ── */
#auth-screen{
  display:flex;align-items:center;justify-content:center;min-height:100vh;
  background:var(--bg);
  background-image:radial-gradient(circle at 20% 50%,rgba(29,158,117,0.08) 0%,transparent 50%),
                   radial-gradient(circle at 80% 20%,rgba(55,138,221,0.07) 0%,transparent 50%);
}
.auth-box{
  background:var(--surface);border:1px solid var(--border);border-radius:22px;
  padding:42px;width:440px;max-width:94vw;box-shadow:0 8px 48px rgba(0,0,0,0.09);
}
.auth-logo{display:flex;align-items:center;gap:12px;margin-bottom:8px;justify-content:center;font-family:var(--head);font-size:24px;font-weight:800;color:var(--text);}
.auth-logo-icon{width:38px;height:38px;background:var(--green);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;}
.auth-tagline{text-align:center;font-size:13px;color:var(--muted);margin-bottom:28px;}
.auth-tabs{display:flex;margin-bottom:26px;border:1.5px solid var(--border);border-radius:10px;overflow:hidden;}
.auth-tab{flex:1;padding:10px;text-align:center;font-size:13px;font-weight:700;cursor:pointer;color:var(--muted);background:transparent;border:none;font-family:var(--font);transition:all .18s;}
.auth-tab.active{background:var(--green);color:#fff;}
.auth-form{display:flex;flex-direction:column;gap:14px;}
.auth-form-hidden{display:none;}
.auth-form label{font-size:11px;color:var(--muted);font-weight:700;display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em;}
.auth-form input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:var(--font);color:var(--text);background:var(--bg);outline:none;transition:border-color .15s;}
.auth-form input:focus{border-color:var(--green);}
.auth-form input::placeholder{color:#C4C9D4;}
.auth-btn{width:100%;padding:12px;background:var(--green);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--font);margin-top:2px;transition:opacity .15s;}
.auth-btn:hover{opacity:.87;}
.auth-btn.ghost{background:var(--surface2);color:var(--text);}
.auth-btn.ghost:hover{background:#E9EBF0;}
.auth-err{font-size:12px;color:var(--red);text-align:center;min-height:16px;font-weight:500;}
.auth-divider{text-align:center;font-size:12px;color:#C4C9D4;position:relative;margin:2px 0;}
.auth-divider::before,.auth-divider::after{content:'';position:absolute;top:50%;width:38%;height:1px;background:var(--border);}
.auth-divider::before{left:0;}.auth-divider::after{right:0;}
.demo-hint{background:rgba(29,158,117,0.07);border:1px solid rgba(29,158,117,0.2);border-radius:10px;padding:10px 14px;font-size:12px;color:#0F6E56;margin-top:4px;}
.demo-hint b{font-weight:700;}

/* ── APP ── */
#app-screen{display:none;min-height:100vh;}
.app-wrap{display:flex;min-height:100vh;}

/* ── Sidebar ── */
.sidebar{width:224px;background:var(--sidebar);display:flex;flex-direction:column;padding:24px 0;position:fixed;top:0;left:0;height:100vh;z-index:10;}
.logo{display:flex;align-items:center;gap:10px;padding:0 20px 22px;font-family:var(--head);font-size:17px;font-weight:800;color:#fff;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:14px;}
.logo-icon{width:30px;height:30px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:17px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:11px 20px;font-size:13px;cursor:pointer;color:rgba(255,255,255,0.42);border-left:2.5px solid transparent;transition:all .18s;font-weight:500;}
.nav-item:hover{color:rgba(255,255,255,0.9);background:rgba(255,255,255,0.05);}
.nav-item.active{color:var(--green);background:rgba(29,158,117,0.13);border-left-color:var(--green);}
.nav-icon{font-size:16px;width:20px;text-align:center;}
.sidebar-bottom{margin-top:auto;padding:0 14px;display:flex;flex-direction:column;gap:8px;}
.user-chip{display:flex;align-items:center;gap:9px;padding:10px 12px;background:rgba(255,255,255,0.06);border-radius:10px;margin-bottom:4px;}
.user-avatar{width:30px;height:30px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;}
.user-name{font-size:12px;color:rgba(255,255,255,0.75);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-role{font-size:10px;color:rgba(255,255,255,0.32);}
#sb-status{font-size:11px;color:var(--green);text-align:center;min-height:16px;padding:0 4px;}
#sb-status.err{color:#FF6B6B;}
.sb-input-hidden{display:none;}
.sb-btn{width:100%;border-radius:10px;padding:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font);transition:all .15s;border:none;}
.sb-green{background:var(--green);color:#fff;} .sb-green:hover{opacity:.85;}
.sb-ghost{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.1)!important;} .sb-ghost:hover{color:#fff;background:rgba(255,255,255,0.12);}
.logout-btn{background:transparent;color:rgba(255,255,255,0.3);border:none;font-size:12px;cursor:pointer;font-family:var(--font);padding:7px;display:flex;align-items:center;gap:6px;width:100%;justify-content:center;border-radius:8px;transition:all .15s;}
.logout-btn:hover{color:#FF6B6B;background:rgba(255,107,107,0.08);}

/* ── Main ── */
.main{margin-left:224px;flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:5;}
.topbar-title{font-family:var(--head);font-size:16px;font-weight:700;color:var(--text);}
.topbar-sub{font-size:12px;color:var(--muted);margin-left:10px;}
.topbar-right{display:flex;gap:10px;align-items:center;}
.content{padding:28px 32px;flex:1;}

/* ── Buttons ── */
.btn-primary{background:var(--green);color:#fff;border:none;border-radius:var(--r);padding:9px 18px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font);transition:opacity .15s;}
.btn-primary:hover{opacity:.88;}
.btn-outline{background:var(--surface);color:var(--text);border:1.5px solid var(--border);border-radius:var(--r);padding:8px 16px;font-size:13px;cursor:pointer;font-family:var(--font);transition:all .15s;white-space:nowrap;font-weight:600;}
.btn-outline:hover{border-color:var(--green);color:var(--green);}
.btn-del{background:transparent;border:none;color:#D1D5DB;cursor:pointer;font-size:14px;padding:3px 7px;border-radius:6px;transition:all .15s;}
.btn-del:hover{color:var(--red);background:var(--rdim);}

/* ── Export dropdown ── */
.export-wrap{position:relative;}
.export-menu{
  display:none;position:absolute;right:0;top:calc(100% + 6px);
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  box-shadow:0 8px 32px rgba(0,0,0,0.12);z-index:50;overflow:hidden;min-width:200px;
}
.export-menu.open{display:block;}
.export-menu-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;padding:12px 16px 8px;}
.export-menu-title-padded{padding-top:8px;}
.export-item{display:flex;align-items:center;gap:10px;padding:10px 16px;cursor:pointer;font-size:13px;color:var(--text);font-weight:500;transition:background .12s;border:none;background:transparent;width:100%;font-family:var(--font);text-align:left;}
.export-item:hover{background:var(--surface2);}
.export-item-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.ei-csv{background:#E6F9F2;} .ei-excel{background:#E8F5E9;} .ei-pdf{background:#FEE8E2;} .ei-png{background:#EEF2FF;}
.export-item-sub{font-size:11px;color:var(--muted);display:block;}
.export-divider{height:1px;background:var(--border);margin:4px 0;}

/* ── Cards ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:20px 24px;}
.card-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:14px;}
.card-title-inline{margin:0;}

/* ── Metrics ── */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:26px;}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:18px 20px;border-top:3px solid var(--ac,var(--green));}
.metric-income{--ac:var(--green);}
.metric-expense{--ac:var(--red);}
.metric-profit{--ac:var(--blue);}
.metric-margin{--ac:var(--yellow);}
.metric-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:7px;font-weight:700;}
.metric-value{font-family:var(--mono);font-size:22px;font-weight:500;color:var(--ac,var(--green));}
.metric-sub{font-size:11px;color:var(--muted);margin-top:5px;}

/* ── Charts ── */
.charts-row{display:grid;grid-template-columns:1.6fr 1fr;gap:18px;margin-bottom:22px;}
.charts-row-equal{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px;}
.chart-container-bar{position:relative;height:210px;}
.chart-container-pie{position:relative;height:160px;}

/* ── Table ── */
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{text-align:left;padding:9px 10px;font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.06em;border-bottom:2px solid var(--border);}
td{padding:11px 10px;border-bottom:1px solid #F3F4F6;color:var(--text);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:#FAFAF9;}
.td-r{text-align:right;}
.badge{font-size:10px;padding:2px 10px;border-radius:20px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;display:inline-block;}
.b-inc{background:rgba(29,158,117,0.12);color:#0F6E56;}
.b-exp{background:rgba(216,90,48,0.12);color:#993C1D;}
.cat-pill{font-size:11px;padding:2px 10px;border-radius:6px;background:var(--surface2);color:var(--muted);font-weight:500;}

/* ── Filter row ── */
.filter-row{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center;}
.filter-row input,.filter-row select{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:8px 12px;font-size:13px;font-family:var(--font);outline:none;transition:border-color .15s;}
.filter-row input:focus,.filter-row select:focus{border-color:var(--green);}
.filter-row input::placeholder{color:#B0B7C3;}
.filter-search-input{width:190px;}
.filter-count-label{font-size:12px;color:var(--muted);margin-left:auto;}

/* ── Modal ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.38);z-index:50;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:28px;width:430px;max-width:92vw;}
.modal-title{font-family:var(--head);font-size:16px;font-weight:700;color:var(--text);margin-bottom:22px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-full{grid-column:1/-1;}
.lbl{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:5px;}
.form-grid input,.form-grid select{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-family:var(--font);color:var(--text);background:var(--bg);outline:none;transition:border-color .15s;}
.form-grid input:focus,.form-grid select:focus{border-color:var(--green);}
.form-grid input::placeholder{color:#B0B7C3;}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:22px;}

/* ── Views ── */
.view{display:none;} .view.active{display:block;}

/* ── Pie legend ── */
.pie-legend{display:flex;flex-direction:column;gap:5px;margin-top:10px;}
.pli{display:flex;align-items:center;gap:8px;font-size:12px;}
.pli-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}
.pli-lbl{flex:1;color:var(--muted);}
.pli-val{font-family:var(--mono);font-weight:500;color:var(--text);}
.total-row td{font-weight:700;background:#F9FBF9;border-top:2px solid var(--border)!important;}
.empty{padding:36px;text-align:center;color:var(--muted);font-size:13px;}

/* Dynamic Context Classes mapping away old inline assignments */
.col-mono-muted{font-family:var(--mono);font-size:12px;color:var(--muted);}
.col-text-medium{font-weight:500;color:var(--text);}
.col-val-income{font-family:var(--mono);font-weight:700;color:var(--green);}
.col-val-expense{font-family:var(--mono);font-weight:700;color:var(--red);}
.col-val-report-inc{font-family:var(--mono);font-weight:600;color:var(--green);}
.col-val-report-exp{font-family:var(--mono);font-weight:600;color:var(--red);}
.col-val-report-prof{font-family:var(--mono);font-weight:700;}
.report-row-title{font-weight:600;color:var(--text);}
.report-margin-text{color:var(--muted);}

/* ── Responsive ── */
@media(max-width:900px){
  .sidebar{width:58px;}
  .logo span,.nav-item span,.user-name,.user-role,.sb-btn span,.logout-btn span,#sb-status{display:none;}
  .logo{padding:0 13px 20px;justify-content:center;}
  .nav-item{justify-content:center;padding:13px;}
  .main{margin-left:58px;}
  .metrics{grid--columns:1fr 1fr;}
  .charts-row{grid-template-columns:1fr;}
  .charts-row-equal{grid-template-columns:1fr;}
  .content{padding:18px 16px;}
}
</style>
</head>
<body>

<div id="auth-screen">
  <div class="auth-box">
    <div class="auth-logo"><div class="auth-logo-icon">💹</div>ProfitLens</div>
    <div class="auth-tagline">Track your income, expenses &amp; profits in real time</div>
    <div class="auth-tabs">
      <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">Sign In</button>
      <button class="auth-tab" id="tab-signup" onclick="switchTab('signup')">Sign Up</button>
    </div>
    <div id="form-login" class="auth-form">
      <div><label>Email</label><input type="email" id="li-email" placeholder="you@example.com" onkeydown="if(event.key==='Enter')doLogin()"/></div>
      <div><label>Password</label><input type="password" id="li-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"/></div>
      <div class="auth-err" id="li-err"></div>
      <button class="auth-btn" onclick="doLogin()">Sign In →</button>
      <div class="auth-divider">or</div>
      <button class="auth-btn ghost" onclick="demoLogin()">🚀 Try Demo Account</button>
      <div class="demo-hint">Demo: <b>demo@profitlens.com</b> / <b>demo123</b><br/>Comes pre-loaded with 6 months of sample data.</div>
    </div>
    <div id="form-signup" class="auth-form auth-form-hidden">
      <div><label>Full Name</label><input type="text" id="su-name" placeholder="Jane Smith"/></div>
      <div><label>Email</label><input type="email" id="su-email" placeholder="you@example.com"/></div>
      <div><label>Password</label><input type="password" id="su-pass" placeholder="Min. 6 characters"/></div>
      <div><label>Confirm Password</label><input type="password" id="su-pass2" placeholder="Repeat password" onkeydown="if(event.key==='Enter')doSignup()"/></div>
      <div class="auth-err" id="su-err"></div>
      <button class="auth-btn" onclick="doSignup()">Create Account →</button>
    </div>
  </div>
</div>

<div id="app-screen">
<div class="app-wrap">
  <nav class="sidebar">
    <div class="logo"><div class="logo-icon">💹</div><span>ProfitLens</span></div>
    <div class="nav-item active" data-view="dashboard"><span class="nav-icon">📊</span><span>Dashboard</span></div>
    <div class="nav-item" data-view="transactions"><span class="nav-icon">↔</span><span>Transactions</span></div>
    <div class="nav-item" data-view="reports"><span class="nav-icon">📄</span><span>Reports</span></div>
    <div class="sidebar-bottom">
      <div class="user-chip">
        <div class="user-avatar" id="user-avatar">D</div>
        <div><div class="user-name" id="user-name-display">Demo User</div><div class="user-role">Account Owner</div></div>
      </div>
      <div id="sb-status"></div>
      <input type="file" id="csv-input" accept=".csv" class="sb-input-hidden"/>
      <button class="sb-btn sb-green" onclick="document.getElementById('csv-input').click()">⬆ <span>Import CSV</span></button>
      <button class="sb-btn sb-ghost" onclick="openModal()">＋ <span>Add Transaction</span></button>
      <button class="logout-btn" onclick="doLogout()">⎋ <span>Sign Out</span></button>
    </div>
  </nav>

  <div class="main">
    <div class="topbar">
      <div>
        <span class="topbar-title" id="page-title">Dashboard</span>
        <span class="topbar-sub" id="txn-count"></span>
      </div>
      <div class="topbar-right">
        <div class="export-wrap" id="export-wrap">
          <button class="btn-outline" onclick="toggleExportMenu()" id="export-btn">⬇ Export ▾</button>
          <div class="export-menu" id="export-menu">
            <div class="export-menu-title">Export Data</div>
            <button class="export-item" onclick="exportCSV()">
              <div class="export-item-icon ei-csv">📄</div>
              <div><span>CSV File</span><span class="export-item-sub">Comma-separated values</span></div>
            </button>
            <button class="export-item" onclick="exportExcel()">
              <div class="export-item-icon ei-excel">📊</div>
              <div><span>Excel (.xlsx)</span><span class="export-item-sub">Microsoft Excel spreadsheet</span></div>
            </button>
            <div class="export-divider"></div>
            <div class="export-menu-title export-menu-title-padded">Export Charts</div>
            <button class="export-item" onclick="exportChartPNG('barChart','income_vs_expenses')">
              <div class="export-item-icon ei-png">🖼</div>
              <div><span>Income vs Expenses</span><span class="export-item-sub">PNG image</span></div>
            </button>
            <button class="export-item" onclick="exportChartPNG('pieChart','expense_breakdown')">
              <div class="export-item-icon ei-png">🖼</div>
              <div><span>Expense Breakdown</span><span class="export-item-sub">PNG image</span></div>
            </button>
            <button class="export-item" onclick="exportChartPNG('lineChart','profit_trend')">
              <div class="export-item-icon ei-png">🖼</div>
              <div><span>Profit Trend</span><span class="export-item-sub">PNG image</span></div>
            </button>
            <div class="export-divider"></div>
            <button class="export-item" onclick="exportPDF()">
              <div class="export-item-icon ei-pdf">📑</div>
              <div><span>Full PDF Report</span><span class="export-item-sub">All data + charts</span></div>
            </button>
          </div>
        </div>
        <button class="btn-primary" onclick="openModal()">＋ Add</button>
      </div>
    </div>

    <div class="content">
      <div class="view active" id="view-dashboard">
        <div class="metrics">
          <div class="metric metric-income"><div class="metric-label">Total Income</div><div class="metric-value" id="m-income">—</div><div class="metric-sub">All time</div></div>
          <div class="metric metric-expense"><div class="metric-label">Total Expenses</div><div class="metric-value" id="m-expense">—</div><div class="metric-sub">All time</div></div>
          <div class="metric metric-profit"><div class="metric-label">Net Profit</div><div class="metric-value" id="m-profit">—</div><div class="metric-sub" id="m-profit-sub"></div></div>
          <div class="metric metric-margin"><div class="metric-label">Profit Margin</div><div class="metric-value" id="m-margin">—</div><div class="metric-sub">Target: 35%</div></div>
        </div>
        <div class="charts-row">
          <div class="card" id="barCard">
            <div class="card-title">Income vs Expenses — Monthly</div>
            <div class="chart-container-bar"><canvas id="barChart"></canvas></div>
          </div>
          <div class="card" id="pieCard">
            <div class="card-title">Expense Breakdown</div>
            <div class="chart-container-pie"><canvas id="pieChart"></canvas></div>
            <div class="pie-legend" id="pie-legend"></div>
