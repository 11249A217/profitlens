  const rows=monthly.map(m=>{
    const pc=m.income>0?((m.profit/m.income)*100).toFixed(1):"0.0";
    const col=m.profit>=0?"var(--blue)":"var(--red)";
    const[y,mo]=m.month.split("-");
    return`<tr>
      <td class="report-row-title">${MONTHS[parseInt(mo)-1]} ${y}</td>
      <td class="td-r col-val-report-inc">+${fmt(m.income)}</td>
      <td class="td-r col-val-report-exp">-${fmt(m.expense)}</td>
      <td class="td-r col-val-report-prof" style="color:${col}">${fmt(m.profit)}</td>
      <td class="td-r report-margin-text">${pc}%</td>
    </tr>`;
  });
  const col2=totals.profit>=0?"var(--blue)":"var(--red)";
  rows.push(`<tr class="total-row"><td>Total</td><td class="td-r col-val-report-inc">+${fmt(totals.income)}</td><td class="td-r col-val-report-exp">-${fmt(totals.expense)}</td><td class="td-r col-val-report-prof" style="color:${col2}">${fmt(totals.profit)}</td><td class="td-r">${totals.margin}%</td></tr>`);
  tbody.innerHTML=rows.join("");
}

