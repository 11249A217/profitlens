function txnRow(t,del){
  const sign=t.type==="income"?"+":"-";
  const customClass=t.type==="income"?"col-val-income":"col-val-expense";
  return `<tr>
    <td class="col-mono-muted">${esc(t.date)}</td>
    <td class="col-text-medium">${esc(t.desc)}</td>
    <td><span class="cat-pill">${esc(t.category)}</span></td>
    <td><span class="badge ${t.type==="income"?"b-inc":"b-exp"}">${t.type}</span></td>
    <td class="td-r ${customClass}">${sign}${fmt(t.amount)}</td>
    ${del?`<td class="td-r"><button class="btn-del" onclick="delTxn(${t.id})" title="Delete">✕</button></td>`:""}
  </tr>`;
}

