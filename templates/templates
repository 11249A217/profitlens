// ── PDF ──
async function exportPDF(){
  closeExportMenu();
  showStatus("⏳ Generating PDF…");
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:"portrait",unit:"mm",format:"a4"});
  const txns=await getData("/transactions");
  const {totals,monthly}=await getData("/summary");
  const W=210,L=10,TW=W-2*L;
  let y=L;

  // Header
  doc.setFillColor(29,158,117);doc.rect(0,0,W,22,"F");
  doc.setTextColor(255,255,255);doc.setFontSize(16);doc.setFont("helvetica","bold");
  doc.text("ProfitLens — Profit & Loss Report",L,14);
  doc.setFontSize(9);doc.setFont("helvetica","normal");
  doc.text("Generated: "+new Date().toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"numeric"}),W-L,14,{align:"right"});
  y=30;

  // Metrics
  const metrics=[["Total Income",fmt(totals.income),"29,158,117"],["Total Expenses",fmt(totals.expense),"216,90,48"],["Net Profit",fmt(totals.profit),"55,138,221"],["Profit Margin",totals.margin+"%","186,117,23"]];
  const mw=(TW-9)/4;
  metrics.forEach((m,i)=>{
    const x=L+i*(mw+3);
    const [r,g,b]=m[2].split(",").map(Number);
    doc.setFillColor(248,247,244);doc.roundedRect(x,y,mw,18,2,2,"F");
    doc.setDrawColor(r,g,b);doc.setLineWidth(0.8);doc.line(x,y,x+mw,y);
    doc.setTextColor(107,114,128);doc.setFontSize(7);doc.setFont("helvetica","bold");
    doc.text(m[0].toUpperCase(),x+3,y+6);
    doc.setTextColor(r,g,b);doc.setFontSize(11);doc.setFont("helvetica","bold");
    doc.text(m[1],x+3,y+13);
  });
  y+=24;

  // Monthly table
  doc.setTextColor(107,114,128);doc.setFontSize(8);doc.setFont("helvetica","bold");
  doc.text("MONTHLY PROFIT & LOSS",L,y);y+=5;
  const cols=["Month","Income","Expenses","Net Profit","Margin"];
  const colW=[38,32,32,36,22];
  // Header row
  doc.setFillColor(248,247,244);doc.rect(L,y,TW,7,"F");
  let cx=L;
  cols.forEach((c,i)=>{
    doc.setTextColor(107,114,128);doc.setFontSize(7.5);doc.setFont("helvetica","bold");
    doc.text(c,cx+(i>0?colW[i]:0),y+5,{align:i>0?"right":"left"});
    cx+=colW[i];
  });
  y+=8;
  monthly.forEach((m,idx)=>{
    if(y>260){doc.addPage();y=15;}
    if(idx%2===0){doc.setFillColor(252,252,251);doc.rect(L,y-1,TW,7,"F");}
    const[yr,mo]=m.month.split("-");
    const label=MONTHS[parseInt(mo)-1]+" "+yr;
    cx=L;
    const vals=[label,"+"+fmt(m.income),"-"+fmt(m.expense),fmt(m.profit),m.margin+"%"];
    vals.forEach((v,i)=>{
      const[r2,g2,b2]=i===0?[17,24,39]:i===1?[29,158,117]:i===2?[216,90,48]:m.profit>=0?[55,138,221]:[216,90,48];
      doc.setTextColor(i===0?107:r2,i===0?114:g2,i===0?128:b2);
      doc.setFontSize(8);doc.setFont("helvetica",i===0?"normal":"bold");
      doc.text(v,cx+(i>0?colW[i]:0),y+4.5,{align:i>0?"right":"left"});
      cx+=colW[i];
    });
    y+=7;
  });

  // Total row
  doc.setFillColor(240,253,248);doc.rect(L,y,TW,8,"F");
  cx=L;
  const totVals=["TOTAL","+"+fmt(totals.income),"-"+fmt(totals.expense),fmt(totals.profit),totals.margin+"%"];
  totVals.forEach((v,i)=>{
    doc.setTextColor(i===0?17:i===1?29:i===2?216:55,i===0?24:i===1?158:i===2?90:138,i===0?39:i===1?117:i===2?48:221);
    doc.setFontSize(8.5);doc.setFont("helvetica","bold");
    doc.text(v,cx+(i>0?colW[i]:0),y+5.5,{align:i>0?"right":"left"});
    cx+=colW[i];
  });
  y+=14;

  // Transactions
  if(y>230){doc.addPage();y=15;}
  doc.setTextColor(107,114,128);doc.setFontSize(8);doc.setFont("helvetica","bold");
  doc.text("TRANSACTION LIST",L,y);y+=5;
  const tCols=["Date","Description","Category","Type","Amount"];
  const tW=[22,70,28,20,30];
  doc.setFillColor(248,247,244);doc.rect(L,y,TW,7,"F");
  let tx=L;
  tCols.forEach((c,i)=>{doc.setTextColor(107,114,128);doc.setFontSize(7.5);doc.setFont("helvetica","bold");doc.text(c,tx+(i>3?tW[i]:0),y+5,{align:i>3?"right":"left"});tx+=tW[i];});
  y+=8;
  txns.slice(0,40).forEach((t,idx)=>{
    if(y>275){doc.addPage();y=15;}
    if(idx%2===0){doc.setFillColor(252,252,251);doc.rect(L,y-1,TW,7,"F");}
    tx=L;
    const tv=[t.date,t.desc.length>38?t.desc.slice(0,36)+"…":t.desc,t.category,t.type,(t.type==="income"?"+":"-")+fmt(t.amount)];
    tv.forEach((v,i)=>{
      const isInc=t.type==="income";
      const clr=i===3?(isInc?[29,158,117]:[216,90,48]):i===4?(isInc?[29,158,117]:[216,90,48]):[107,114,128];
      doc.setTextColor(...clr);doc.setFontSize(7.5);doc.setFont("helvetica",i===4?"bold":"normal");
      doc.text(v,tx+(i>3?tW[i]:0),y+4.5,{align:i>3?"right":"left"});
      tx+=tW[i];
    });
    y+=7;
  });
  if(txns.length>40){doc.setTextColor(150,150,150);doc.setFontSize(7);doc.text(`… and ${txns.length-40} more transactions`,L,y+4);}

  // Footer
  const pages=doc.getNumberOfPages();
  for(let p=1;p<=pages;p++){
    doc.setPage(p);
    doc.setFillColor(248,247,244);doc.rect(0,285,W,12,"F");
    doc.setTextColor(150,150,150);doc.setFontSize(7);
    doc.text("ProfitLens — Confidential",L,291);
    doc.text(`Page ${p} of ${pages}`,W-L,291,{align:"right"});
  }

  doc.save(`profitlens_report_${today()}.pdf`);
  showStatus("✓ PDF report exported!");
}

function closeExportMenu(){document.getElementById("export-menu").classList.remove("open");}
function today(){return new Date().toISOString().slice(0,10);}
function dlBlob(blob,name){const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download=name;a.click();}
