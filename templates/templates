function openModal(){document.getElementById("inp-date").value=new Date().toISOString().slice(0,10);document.getElementById("modal-overlay").classList.add("open");}
function closeModal(){document.getElementById("modal-overlay").classList.remove("open");}
function autoCat(){
  const d=document.getElementById("inp-desc").value.toLowerCase();
  let cat="Other";
  if(d.includes("payroll")||d.includes("salary"))cat="Payroll";
  else if(d.includes("aws")||d.includes("cloud")||d.includes("figma")||d.includes("software")||d.includes("subscript"))cat="Software";
  else if(d.includes("ads")||d.includes("marketing")||d.includes("seo"))cat="Marketing";
  else if(d.includes("rent")||d.includes("office")||d.includes("operations"))cat="Operations";
  else if(d.includes("licence")||d.includes("license"))cat="Licences";
  else if(d.includes("product sale")||d.includes("sale "))cat="Sales";
  else if(d.includes("client")||d.includes("consulting")||d.includes("retainer")||d.includes("payment"))cat="Services";
  const sel=document.getElementById("inp-cat");
  for(let o of sel.options)if(o.value===cat){sel.value=cat;break;}
}
async function submitTxn(){
  const body={date:document.getElementById("inp-date").value,desc:document.getElementById("inp-desc").value.trim(),type:document.getElementById("inp-type").value,category:document.getElementById("inp-cat").value,amount:parseFloat(document.getElementById("inp-amount").value)};
  if(!body.date||!body.desc||isNaN(body.amount)||body.amount<=0){showStatus("⚠ Fill all fields correctly.",true);return;}
  await getData("/transactions",{method:"POST",body:JSON.stringify(body)});
  showStatus("✓ Transaction added!");closeModal();
  document.getElementById("inp-desc").value="";document.getElementById("inp-amount").value="";
  loadDashboard();
}

// ══════════════════════════════════════════════
//  CSV IMPORT
// ══════════════════════════════════════════════
document.getElementById("csv-input").addEventListener("change",async(e)=>{
  const file=e.target.files[0];if(!file)return;
  // Always parse CSV locally (app runs fully client-side)
  const text=await file.text();
  const lines=text.trim().split("\n");
  if(lines.length<2){showStatus("⚠ CSV has no data rows.",true);e.target.value="";return;}
  const headers=lines[0].split(",").map(h=>h.trim().toLowerCase().replace(/^"|"$/g,""));
  let count=0;
  for(let i=1;i<lines.length;i++){
    const cols=lines[i].split(",").map(c=>c.trim().replace(/^"|"$/g,""));
    const obj={};headers.forEach((h,idx)=>{obj[h]=cols[idx]||"";});
    const amount=Math.abs(parseFloat(obj.amount||obj.value||"0"));
    const desc=(obj.description||obj.desc||obj.name||"").trim();
    if(!desc||isNaN(amount)||amount<=0)continue;
    LOCAL_TXN.unshift({id:++nextId,date:obj.date||new Date().toISOString().slice(0,10),desc,category:obj.category||"Other",type:(obj.type||"income").toLowerCase().includes("exp")?"expense":"income",amount});
    count++;
  }
  if(count===0){showStatus("⚠ No valid rows found. Check CSV columns.",true);e.target.value="";return;}
  showStatus("✓ Imported "+count+" row"+(count!==1?"s":"")+"!");
  loadDashboard();
  if(document.getElementById("view-transactions").classList.contains("active"))loadTxns();
  e.target.value="";
});

