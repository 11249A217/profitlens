function computeSummary(txns){
  const income=txns.filter(t=>t.type==="income").reduce((s,t)=>s+t.amount,0);
  const expense=txns.filter(t=>t.type==="expense").reduce((s,t)=>s+t.amount,0);
  const profit=income-expense;
  const margin=income>0?+((profit/income)*100).toFixed(1):0;

  const monthMap={};
  txns.forEach(t=>{
    const m=t.date.slice(0,7);
    if(!monthMap[m]) monthMap[m]={month:m,income:0,expense:0};
    if(t.type==="income") monthMap[m].income+=t.amount;
    else monthMap[m].expense+=t.amount;
  });
  const monthly=Object.values(monthMap).sort((a,b)=>a.month.localeCompare(b.month))
    .map(d=>({...d,profit:d.income-d.expense,margin:d.income>0?+((d.income-d.expense)/d.income*100).toFixed(1):0}));

  const catMap={};
  txns.filter(t=>t.type==="expense").forEach(t=>{catMap[t.category]=(catMap[t.category]||0)+t.amount;});
  const categories=Object.entries(catMap).map(([category,total])=>({category,total})).sort((a,b)=>b.total-a.total);

  return{totals:{income,expense,profit,margin},monthly,categories};
}

async function getData(path,opts={}){
  if(USE_DEMO || !USE_DEMO){
    // Route locally for storage fallback scenario requested
    if(path.startsWith("/summary")) return computeSummary(LOCAL_TXN);
    if(path.startsWith("/categories")) return [...new Set(LOCAL_TXN.map(t=>t.category))].sort();
    if(path.startsWith("/transactions/")){
      const id=parseInt(path.split("/").pop());
      if(opts.method==="DELETE"){LOCAL_TXN=LOCAL_TXN.filter(t=>t.id!==id);return{deleted:id};}
    }
    if(path.startsWith("/transactions")&&opts.method==="POST"){
      const body=JSON.parse(opts.body);
      const t={...body,id:++nextId,amount:parseFloat(body.amount)};
      LOCAL_TXN.unshift(t); return t;
    }
    if(path.startsWith("/transactions")){
      const p=new URLSearchParams(path.includes("?")?path.split("?")[1]:"");
      let res=[...LOCAL_TXN];
      if(p.get("search")){const s=p.get("search").toLowerCase();res=res.filter(t=>t.desc.toLowerCase().includes(s)||t.category.toLowerCase().includes(s));}
      if(p.get("type")) res=res.filter(t=>t.type===p.get("type"));
      if(p.get("category")) res=res.filter(t=>t.category===p.get("category"));
      if(p.get("month")) res=res.filter(t=>t.date.startsWith(p.get("month")));
      return res.sort((a,b)=>b.date.localeCompare(a.date));
    }
    return [];
  }
  // Real API Fallback if needed
  try{
    const res=await fetch(API+path,{headers:{"Content-Type":"application/json"},...opts});
    if(!res.ok){const e=await res.json();throw new Error(e.error||"API error");}
    return await res.json();
  }catch(err){showStatus("⚠ "+err.message,true);throw err;}
}

