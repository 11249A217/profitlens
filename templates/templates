// ── CSV ──
async function exportCSV(){
  closeExportMenu();
  const txns=await getData("/transactions");
  const header="id,date,description,category,type,amount";
  const rows=txns.map(t=>`${t.id},${t.date},"${t.desc}",${t.category},${t.type},${t.amount}`);
  const blob=new Blob([header+"\n"+rows.join("\n")],{type:"text/csv"});
  dlBlob(blob,`profitlens_${today()}.csv`);
  showStatus("✓ CSV exported!");
}

// ── Excel ──
async function exportExcel(){
  closeExportMenu();
  const txns=await getData("/transactions");
  const summary=await getData("/summary");
  const wb=XLSX.utils.book_new();

  // Transactions sheet
  const txnData=[["ID","Date","Description","Category","Type","Amount"],...txns.map(t=>[t.id,t.date,t.desc,t.category,t.type,t.amount])];
  const ws1=XLSX.utils.aoa_to_sheet(txnData);
  ws1["!cols"]=[{wch:6},{wch:12},{wch:40},{wch:14},{wch:10},{wch:12}];
  XLSX.utils.book_append_sheet(wb,ws1,"Transactions");

  // Summary sheet
  const {totals,monthly}=summary;
  const sumData=[
    ["ProfitLens — P&L Summary",""],["",""],
    ["TOTALS",""],
    ["Total Income",totals.income],["Total Expenses",totals.expense],["Net Profit",totals.profit],["Profit Margin (%)",totals.margin],
    ["",""],["MONTHLY BREAKDOWN",""],
    ["Month","Income","Expenses","Net Profit","Margin (%)"],
    ...monthly.map(m=>{const[y,mo]=m.month.split("-");return[MONTHS[parseInt(mo)-1]+" "+y,m.income,m.expense,m.profit,m.margin];})
  ];
  const ws2=XLSX.utils.aoa_to_sheet(sumData);
  ws2["!cols"]=[{wch:20},{wch:16},{wch:16},{wch:16},{wch:14}];
  XLSX.utils.book_append_sheet(wb,ws2,"Summary");

  XLSX.writeFile(wb,`profitlens_${today()}.xlsx`);
  showStatus("✓ Excel exported!");
}

